{
  "name": "claw-hive",
  "version": "1.0.0",
  "description": "Real-time monitoring dashboard for OpenClaw AI agents",
  "main": "src/server.js",
  "bin": {
    "claw-hive": "./bin/cli.js",
    "openclaw-dashboard": "./bin/cli.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev:server": "node src/server.js",
    "dev:ui": "cd dashboard && npx vite",
    "build": "cd dashboard && npx vite build --outDir ../public",
    "prepublishOnly": "npm run build",
    "test": "node tests/smoke.test.js",
    "evolve": "node evolution/runner.js",
    "test:watch": "node tests/smoke.test.js",
    "test:unit": "vitest run",
    "test:integration": "node tests/integration.test.js"
  },
  "keywords": [
    "openclaw",
    "dashboard",
    "ai-agent",
    "monitoring"
  ],
  "author": "Arthur",
  "license": "MIT",
  "files": [
    "bin/",
    "src/",
    "public/",
    "README.md"
  ],
  "dependencies": {
    "commander": "^11.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "eventsource": "^4.1.0",
    "express": "^4.18.0",
    "fs-extra": "^11.3.4",
    "open": "^9.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "react-router-dom": "^7.13.1",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.16.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

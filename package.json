{
  "name": "claw-hive",
  "version": "1.0.0",
  "description": "Real-time monitoring dashboard for OpenClaw AI agents",
  "main": "src/server.js",
  "bin": {
    "claw-hive": "./bin/cli.js",
    "openclaw-dashboard": "./bin/cli.js"
  },
  "scripts": {
    "start": "npx ts-node --compilerOptions \"{\\\"module\\\":\\\"commonjs\\\"}\" src/server.ts",
    "dev:server": "npx ts-node --compilerOptions \"{\\\"module\\\":\\\"commonjs\\\"}\" src/server.ts",
    "dev:ui": "cd dashboard && npx vite",
    "build": "cd dashboard && npx vite build --outDir ../public",
    "prepublishOnly": "npm run build",
    "test": "node tests/smoke.test.js",
    "evolve": "node evolution/runner.js"
  },
  "keywords": [
    "openclaw",
    "dashboard",
    "ai-agent",
    "monitoring"
  ],
  "author": "Arthur",
  "license": "MIT",
  "files": [
    "bin/",
    "src/",
    "public/",
    "README.md"
  ],
  "dependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "commander": "^11.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "eventsource": "^4.1.0",
    "express": "^4.18.0",
    "fs-extra": "^11.3.4",
    "open": "^9.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react-router-dom": "^7.13.1",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.16.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

#!/usr/bin/env node
// @ts-nocheck

/**
 * LLM Proxy Service - 独立进程
 * 运行: node src/proxy.ts
 * 端口: 8999
 */

const express = require('express');
const cors = require('cors');
const http = require('http');
const path = require('path');
const fs = require('fs');

const PROXY_PORT = process.env.PROXY_PORT || 8999;

const app = express();
app.use(cors());
app.use(express.json({ limit: '50mb' }));

// Captures storage
const captures: any[] = [];
const MAX_CAPTURES = 100;

// Logging
app.use((req, res, next) => {
  console.log(`[PROXY] ${req.method} ${req.path}`);
  next();
});

// Health
app.get('/_health', (req, res) => {
  res.json({ 
    status: 'ok', 
    uptime: startedAt ? Math.round((Date.now() - startedAt.getTime()) / 1000) : 0,
    captures: captures.length 
  });
});

// Start proxy
let server: any;
let startedAt: Date | null = null;

app.post('/api/start', async (req, res) => {
  const { port = 8999, targetUrl } = req.body;
  
  if (server) {
    return res.json({ success: true, port: PROXY_PORT, message: 'Already running' });
  }
  
  // Forward all requests to target LLM
  app.all('/*', async (req, res) => {
    const targetPath = req.path.replace('/api/', '/');
    const targetBase = targetUrl || 'https://api.minimax.io/anthropic';
    const url = `${targetBase}${targetPath}`;
    
    try {
      const forwardOptions: any = {
        method: req.method,
        headers: { ...req.headers },
      };
      delete forwardOptions.headers.host;
      
      if (req.body) {
        forwardOptions.body = JSON.stringify(req.body);
      }
      
      const response = await fetch(url, forwardOptions);
      const contentType = response.headers.get('content-type') || '';
      
      if (contentType.includes('text/event-stream')) {
        res.setHeader('Content-Type', 'text/event-stream');
        res.setHeader('Cache-Control', 'no-cache');
        res.setHeader('Connection', 'keep-alive');
        
        const reader = response.body?.getReader();
        if (reader) {
          const decoder = new TextDecoder();
          while (true) {
            const { done, value } = await reader.read();
            if (done) break;
            res.write(decoder.decode(value));
          }
          res.end();
        } else {
          res.send(await response.text());
        }
      } else {
        const body = await response.text();
        res.status(response.status).send(body);
      }
    } catch (err: any) {
      res.status(500).json({ error: err.message });
    }
  });

  server = http.createServer(app);
  server.listen(PROXY_PORT, () => {
    startedAt = new Date();
    console.log(`[PROXY] Running on port ${PROXY_PORT}`);
    res.json({ success: true, port: PROXY_PORT });
  });
});

// Stop proxy
app.post('/api/stop', (req, res) => {
  if (server) {
    server.close();
    server = null;
    startedAt = null;
    res.json({ success: true });
  } else {
    res.json({ success: false, error: 'Not running' });
  }
});

// Get captures
app.get('/api/captures', (req, res) => {
  const limit = parseInt(req.query.limit as string) || 50;
  res.json(captures.slice(-limit).reverse());
});

// Get single capture
app.get('/api/captures/:id', (req, res) => {
  const id = parseInt(req.params.id);
  const capture = captures.find(c => c.callId === id);
  if (capture) {
    res.json(capture);
  } else {
    res.status(404).json({ error: 'Not found' });
  }
});

console.log('[PROXY] Use POST /api/start to begin');

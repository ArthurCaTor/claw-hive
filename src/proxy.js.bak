// LLM Proxy Service - Independent Process
// Run: node src/proxy.js

const express = require('express');
const cors = require('cors');
const http = require('http');

const PROXY_PORT = process.env.PROXY_PORT || 8999;

const app = express();
app.use(cors());
app.use(express.json({ limit: '50mb' }));

const captures = [];
const MAX_CAPTURES = 100;

let startTime = null;
let proxyActive = false;

// Logging
app.use((req, res, next) => {
  console.log(`[PROXY] ${req.method} ${req.path}`);
  next();
});

// Health
app.get('/_health', (req, res) => {
  res.json({ 
    status: 'ok', 
    uptime: startTime ? Math.round((Date.now() - startTime.getTime()) / 1000) : 0,
    captures: captures.length,
    proxyActive: proxyActive
  });
});

// Start proxy
app.post('/api/start', async (req, res) => {
  if (proxyActive) {
    return res.json({ success: true, port: PROXY_PORT, message: 'Already active' });
  }
  
  proxyActive = true;
  startTime = new Date();
  
  // Catch-all proxy
  app.all('/*', async (req, res) => {
    if (!proxyActive) return res.status(503).json({ error: 'Proxy not active' });
    
    const path = req.path.replace(/^\/api\//, '');
    const targetUrl = req.body?._targetUrl || 'https://api.minimax.io/anthropic';
    const url = `${targetUrl}/${path}`;
    
    const capturedRequest = { callId: captures.length, method: req.method, path: req.path, target: url, timestamp: new Date().toISOString() };
    
    try {
      const response = await fetch(url, { method: req.method, body: req.body ? JSON.stringify(req.body) : undefined });
      const contentType = response.headers.get('content-type') || '';
      
      if (contentType.includes('text/event-stream')) {
        res.setHeader('Content-Type', 'text/event-stream');
        const reader = response.body.getReader();
        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          res.write(value);
        }
        res.end();
        capturedRequest.response = { status: response.status, streaming: true };
      } else {
        const text = await response.text();
        res.status(response.status).send(text);
        capturedRequest.response = { status: response.status, bodyPreview: text.substring(0, 500) };
      }
      
      captures.push(capturedRequest);
      if (captures.length > MAX_CAPTURES) captures.shift();
    } catch (err) {
      res.status(500).json({ error: err.message });
    }
  });
  
  console.log(`[PROXY] Active on port ${PROXY_PORT}`);
  res.json({ success: true, port: PROXY_PORT });
});

// Stop proxy
app.post('/api/stop', (req, res) => {
  proxyActive = false;
  res.json({ success: true });
});

// Captures
app.get('/api/captures', (req, res) => {
  const limit = parseInt(req.query.limit) || 50;
  res.json(captures.slice(-limit).reverse());
});

app.get('/api/captures/:id', (req, res) => {
  const id = parseInt(req.params.id);
  res.json(captures[id] || { error: 'Not found' });
});

app.get('/', (req, res) => {
  res.json({ service: 'llm-proxy', port: PROXY_PORT, active: proxyActive });
});

// Start server
const server = app.listen(PROXY_PORT, () => {
  console.log(`[PROXY] Running on port ${PROXY_PORT}`);
});

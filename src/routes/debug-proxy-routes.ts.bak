// @ts-nocheck
// Debug Proxy Routes - External Proxy 模式

const express = require('express');
const { Router } = require('express');
const http = require('http');

const PROXY_URL = process.env.PROXY_URL || 'http://localhost:8999';

const router = Router();

// Helper to call proxy
function proxyReq(method, path, body) {
  return new Promise((resolve, reject) => {
    const url = new URL(path, PROXY_URL);
    const options = {
      hostname: url.hostname,
      port: url.port,
      path: url.pathname,
      method,
      headers: { 'Content-Type': 'application/json' }
    };
    const req = http.request(options, (res) => {
      let data = '';
      res.on('data', c => data += c);
      res.on('end', () => {
        try { resolve(JSON.parse(data)); }
        catch { resolve(data); }
      });
    });
    req.on('error', reject);
    if (body) req.write(JSON.stringify(body));
    req.end();
  });
}

// Proxy status
router.get('/api/debug-proxy/status', async (req, res) => {
  try {
    const status = await proxyReq('GET', '/_health');
    res.json({ 
      running: true, 
      port: 8999, 
      capturesCount: status.captures || 0 
    });
  } catch {
    res.json({ running: false, port: 8999, capturesCount: 0 });
  }
});

// Start proxy
router.post('/api/debug-proxy/start', async (req, res) => {
  try {
    const result = await proxyReq('POST', '/api/start', req.body);
    res.json(result);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

// Stop proxy  
router.post('/api/debug-proxy/stop', async (req, res) => {
  try {
    const result = await proxyReq('POST', '/api/stop');
    res.json(result);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

// Captures
router.get('/api/debug-proxy/captures', async (req, res) => {
  try {
    const captures = await proxyReq('GET', '/api/captures?limit=50');
    res.json(captures);
  } catch (err) {
    res.json([]);
  }
});

router.get('/api/debug-proxy/captures/:id', async (req, res) => {
  try {
    const capture = await proxyReq('GET', `/api/captures/${req.params.id}`);
    res.json(capture);
  } catch {
    res.status(404).json({ error: 'Not found' });
  }
});

module.exports = router;

  <text x="75" y="38" font-family="Arial" font-size="9" fill="#DDD" text-anchor="middle">Claude Sonnet</text>
</g>

<!-- ============ LAYER 2: Gateway ============ -->
<line x1="155" y1="170" x2="700" y2="210" stroke="#94A3B8" stroke-width="2" marker-end="url(#arrow)"/>
<line x1="325" y1="170" x2="700" y2="210" stroke="#94A3B8" stroke-width="2" marker-end="url(#arrow)"/>
<line x1="495" y1="170" x2="700" y2="210" stroke="#94A3B8" stroke-width="2" marker-end="url(#arrow)"/>
<line x1="665" y1="170" x2="700" y2="210" stroke="#94A3B8" stroke-width="2" marker-end="url(#arrow)"/>
<line x1="835" y1="170" x2="700" y2="210" stroke="#94A3B8" stroke-width="2" marker-end="url(#arrow)"/>
<line x1="1005" y1="170" x2="700" y2="210" stroke="#94A3B8" stroke-width="2" marker-end="url(#arrow)"/>

<rect x="550" y="210" width="300" height="50" rx="10" fill="#7C3AED" filter="url(#shadow)"/>
<text x="700" y="240" font-family="Arial" font-size="14" font-weight="bold" fill="white" text-anchor="middle">OpenClaw Gateway</text>

<!-- ============ LAYER 3: Server ============ -->
<line x1="700" y1="260" x2="700" y2="310" stroke="#94A3B8" stroke-width="2" marker-end="url(#arrow)"/>

<rect x="150" y="310" width="1100" height="280" rx="12" fill="#F0FDF4" stroke="#059669" stroke-width="2"/>
<text x="170" y="340" font-family="Arial" font-size="14" font-weight="bold" fill="#059669">claw-hive Server (:8080)</text>
<text x="170" y="360" font-family="Arial" font-size="10" fill="#64748B">TypeScript + WebSocket + Prometheus Metrics</text>

<!-- Services Grid -->
<rect x="180" y="380" width="160" height="90" rx="8" fill="#059669"/>
<text x="260" y="410" font-family="Arial" font-size="11" fill="white" text-anchor="middle">LLM Proxy</text>
<text x="260" y="430" font-family="Arial" font-size="9" fill="#DDD" text-anchor="middle">Passive Mode</text>

<rect x="360" y="380" width="160" height="90" rx="8" fill="#0891B2"/>
<text x="440" y="410" font-family="Arial" font-size="11" fill="white" text-anchor="middle">Token Aggregator</text>
<text x="440" y="430" font-family="Arial" font-size="9" fill="#DDD" text-anchor="middle">Real-time Stats</text>

<rect x="540" y="380" width="160" height="90" rx="8" fill="#DC2626"/>
<text x="620" y="410" font-family="Arial" font-size="11" fill="white" text-anchor="middle">Cost Calculator</text>
<text x="620" y="430" font-family="Arial" font-size="9" fill="#DDD" text-anchor="middle">Usage Tracking</text>

<rect x="720" y="380" width="160" height="90" rx="8" fill="#7C3AED"/>
<text x="800" y="410" font-family="Arial" font-size="11" fill="white" text-anchor="middle">LLM Tracker</text>
<text x="800" y="430" font-family="Arial" font-size="9" fill="#DDD" text-anchor="middle">Switch Detection</text>

<rect x="900" y="380" width="160" height="90" rx="8" fill="#EA580C"/>
<text x="980" y="410" font-family="Arial" font-size="11" fill="white" text-anchor="middle">Alert Service</text>
<text x="980" y="430" font-family="Arial" font-size="9" fill="#DDD" text-anchor="middle">5 Rules Active</text>

<rect x="180" y="490" width="160" height="90" rx="8" fill="#059669"/>
<text x="260" y="520" font-family="Arial" font-size="11" fill="white" text-anchor="middle">Message Optimizer</text>
<text x="260" y="540" font-family="Arial" font-size="9" fill="#DDD" text-anchor="middle">Active Mode (Optional)</text>

<rect x="360" y="490" width="160" height="90" rx="8" fill="#0891B2"/>
<text x="440" y="520" font-family="Arial" font-size="11" fill="white" text-anchor="middle">WebSocket Server</text>
<text x="440" y="540" font-family="Arial" font-size="9" fill="#DDD" text-anchor="middle">Real-time Updates</text>

<rect x="540" y="490" width="160" height="90" rx="8" fill="#475569"/>
<text x="620" y="520" font-family="Arial" font-size="11" fill="white" text-anchor="middle">Metrics Exporter</text>
<text x="620" y="540" font-family="Arial" font-size="9" fill="#DDD" text-anchor="middle">Prometheus</text>

<!-- ============ LAYER 4: API Endpoints ============ -->
<line x1="700" y1="580" x2="700" y2="620" stroke="#94A3B8" stroke-width="2" marker-end="url(#arrow)"/>

<rect x="50" y="620" width="1300" height="70" rx="12" fill="#F8FAFC" stroke="#E2E8F0" stroke-width="1"/>
<text x="70" y="645" font-family="Arial" font-size="10" font-weight="bold" fill="#64748B">API Endpoints:</text>
<text x="70" y="670" font-family="Courier" font-size="9" fill="#475569">/api/health | /api/debug-proxy/captures | /api/stats/tokens | /api/cost/summary | /api/llm-tracker/* | /api/alerts/* | /metrics</text>

<!-- ============ LAYER 5: LLM Providers ============ -->
<line x1="700" y1="690" x2="700" y2="730" stroke="#94A3B8" stroke-width="2" marker-end="url(#arrow)"/>

<rect x="100" y="730" width="1200" height="80" rx="12" fill="#FFF7ED" stroke="#EA580C" stroke-width="2"/>
<text x="120" y="760" font-family="Arial" font-size="12" font-weight="bold" fill="#EA580C">LLM Providers</text>

<rect x="150" y="770" width="180" height="30" rx="6" fill="#EA580C"/>
<text x="240" y="790" font-family="Arial" font-size="10" fill="white" text-anchor="middle">MiniMax</text>

<rect x="450" y="770" width="180" height="30" rx="6" fill="#10B981"/>
<text x="540" y="790" font-family="Arial" font-size="10" fill="white" text-anchor="middle">OpenAI</text>

<rect x="750" y="770" width="180" height="30" rx="6" fill="#6366F1"/>
<text x="840" y="790" font-family="Arial" font-size="10" fill="white" text-anchor="middle">Anthropic</text>


  <rect x="0" y="0" width="150" height="55" rx="8" fill="#4F46E5" filter="url(#shadow)"/>
  <text x="75" y="20" font-family="Arial" font-size="11" fill="white" text-anchor="middle">User D</text>
  <text x="75" y="38" font-family="Arial" font-size="9" fill="#DDD" text-anchor="middle">OpenAI GPT-4o</text>
</g>
<g transform="translate(760, 115)">
  <rect x="0" y="0" width="150" height="55" rx="8" fill="#4F46E5" filter="url(#shadow)"/>
  <text x="75" y="20" font-family="Arial" font-size="11" fill="white" text-anchor="middle">User E</text>
  <text x="75" y="38" font-family="Arial" font-size="9" fill="#DDD" text-anchor="middle">Claude Sonnet</text>
</g>
